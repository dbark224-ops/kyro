{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@kyro/contracts": ["packages/contracts/src/index.ts"],
      "@kyro/core": ["packages/core/src/index.ts"],
      "@kyro/db": ["packages/db/src/index.ts"],
      "@kyro/api": ["packages/api/src/index.ts"],
      "@kyro/ai": ["packages/ai/src/index.ts"],
      "@kyro/jobs": ["packages/jobs/src/index.ts"]
    }
  }
}
